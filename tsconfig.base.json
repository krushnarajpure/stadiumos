{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@stadiumos/shared/*": ["shared/*"],
      "@stadiumos/schemas/*": ["libs/schemas/*"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
